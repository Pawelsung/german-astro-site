---
import VerbWithPreposition from '../components/VerbWithPreposition.jsx';

export const frontmatter = {
  title: "Lektion 2: 基礎動詞介系詞特訓",
  description: "這是一個專為德語學習者設計的互動式工具。本課將帶領你深入練習動詞與介系詞的搭配，這也是德語學習中最具挑戰性的部分之一。",
  category: "德語文法特訓",
  tags: ["B1-B2", "Akkusativ", "Dativ", "互動學習", "SRS系統"]
};
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{frontmatter.title}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <style is:global>
        body { 
            font-family: 'Nunito', 'Noto Sans TC', sans-serif; 
            background-color: #FDFBF7; 
            margin: 0;
            padding: 0;
            overscroll-behavior-y: none; /* 防止手機瀏覽器出現橡皮筋彈跳 */
        }
        
        /* 隱藏網頁預設卷軸，讓畫面更像 App */
        ::-webkit-scrollbar {
            display: none;
        }
        * {
            -ms-overflow-style: none;
            scrollbar-width: none;
            -webkit-tap-highlight-color: transparent; /* 移除手機點擊閃爍 */
        }
    </style>
</head>
<body class="text-slate-800 min-h-screen flex flex-col">

    {/* 上半部：標題與介紹 */}
    <div class="w-full px-4 pt-8 pb-2">
        <div class="max-w-4xl mx-auto">
            <a href="/" class="text-amber-600 font-black mb-6 inline-flex items-center gap-2 hover:bg-amber-50 px-4 py-2 rounded-xl transition-all">
                ← 返回課程總覽
            </a>
            
            <h1 class="text-3xl md:text-5xl font-black text-slate-800 mb-4 tracking-tight leading-tight">
                {frontmatter.title}
            </h1>
            
            <div class="flex flex-wrap gap-2 mb-6">
                {frontmatter.tags.map((tag) => (
                    <span class="px-3 py-1 bg-amber-50 text-amber-600 text-xs font-black rounded-full border border-amber-100 shadow-sm">
                        #{tag}
                    </span>
                ))}
            </div>
            
            <p class="text-slate-600 leading-relaxed font-medium text-sm md:text-base">
                {frontmatter.description}
            </p>
        </div>
    </div>

    {/* 中間部：APP 互動區 (透過 client:only 確保 React 完美在客戶端渲染) */}
    <div class="w-full flex-grow relative z-10 px-0">
        <VerbWithPreposition client:only="react" />
    </div>

    {/* 下半部：學習小撇步 (緊貼在 App 下方) */}
    <div class="w-full px-4 pb-12 mt-2 mb-8 relative z-0">
        <div class="max-w-4xl mx-auto bg-amber-50 p-6 rounded-[2rem] border border-amber-100 shadow-sm">
            <h3 class="text-lg font-black text-amber-800 mb-4 flex items-center gap-2">
                <span class="text-2xl">💡</span> 學習小撇步
            </h3>
            <ul class="space-y-4 text-sm text-amber-700 font-bold">
                <li class="flex items-start gap-2">
                    <span class="text-amber-400 mt-0.5">•</span>
                    <span>善用收藏功能：遇到老是記不住的動詞，點擊右上角星星收藏，之後可專門針對收藏單字測驗。</span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="text-amber-400 mt-0.5">•</span>
                    <span>聆聽發音：點擊喇叭按鈕聆聽 AI 發音，大聲跟讀模仿語調，能加深大腦記憶。</span>
                </li>
                <li class="flex items-start gap-2">
                    <span class="text-amber-400 mt-0.5">•</span>
                    <span>注意格位：德文介系詞後面接 Akkusativ 通常有「方向、目標性」，接 Dativ 則多與「狀態、位置」有關。</span>
                </li>
            </ul>
        </div>
    </div>

</body>
</html>