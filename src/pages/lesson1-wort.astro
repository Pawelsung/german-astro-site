---
import Layout from '../layouts/Layout.astro';

export const frontmatter = {
  title: "Lektion 1: 德語名詞練習",
  description: "包含了閃卡、詞性、聽寫與字典的完整綜合練習平台。可自製單字卡上傳練習（json檔）",
  category: "德語文法特訓",
  tags: ["全功能", "聽寫", "雲端同步"]
};
---

<Layout title={frontmatter.title}>
  <main class="min-h-screen bg-[#FDFBF7] text-slate-800 flex flex-col">
    <div class="w-full px-4 pt-8 pb-2">
      <div class="max-w-4xl mx-auto">
        <a
          href="/"
          class="text-amber-600 font-black mb-6 inline-flex items-center gap-2 hover:bg-amber-50 px-4 py-2 rounded-xl transition-all"
        >
          ← 返回課程總覽
        </a>

        <h1 class="text-3xl md:text-5xl font-black text-slate-800 mb-4 tracking-tight leading-tight">
          {frontmatter.title}
        </h1>

        <div class="flex flex-wrap gap-2 mb-6">
          {frontmatter.tags.map((tag) => (
            <span class="px-3 py-1 bg-amber-50 text-amber-600 text-xs font-black rounded-full border border-amber-100 shadow-sm">
              #{tag}
            </span>
          ))}
        </div>

        <p class="text-slate-600 leading-relaxed font-medium text-sm md:text-base">
          {frontmatter.description}
        </p>
      </div>
    </div>

    <div class="w-full flex-grow px-4 pb-10">
      <div class="max-w-6xl mx-auto">
        <div class="bg-white border border-slate-200 rounded-[2rem] shadow-sm overflow-hidden">
          <iframe
            id="lesson1-frame"
            src="/lesson1-platform.html"
            title="Lektion 1 platform"
            class="w-full border-0 block"
            style="height: 900px;"
            loading="eager"
          ></iframe>
        </div>
      </div>
    </div>
  </main>

  <script>
    function resizeLesson1Frame() {
      const iframe = document.getElementById('lesson1-frame');
      if (!iframe) return;

      try {
        const doc = iframe.contentWindow?.document;
        if (!doc) return;

        const body = doc.body;
        const html = doc.documentElement;

        const height = Math.max(
          body.scrollHeight,
          body.offsetHeight,
          html.clientHeight,
          html.scrollHeight,
          html.offsetHeight
        );

        iframe.style.height = `${height}px`;
      } catch (e) {
        console.warn('iframe 高度自動調整失敗', e);
      }
    }

    window.addEventListener('load', () => {
      const iframe = document.getElementById('lesson1-frame');
      if (!iframe) return;

      iframe.addEventListener('load', () => {
        resizeLesson1Frame();

        try {
          const iframeWindow = iframe.contentWindow;
          iframeWindow?.addEventListener('resize', resizeLesson1Frame);

          const iframeDoc = iframeWindow?.document;
          const observerTarget = iframeDoc?.body;
          if (observerTarget) {
            const observer = new ResizeObserver(() => resizeLesson1Frame());
            observer.observe(observerTarget);
          }
        } catch (e) {
          console.warn('無法監聽 iframe 內容變化', e);
        }

        setTimeout(resizeLesson1Frame, 300);
        setTimeout(resizeLesson1Frame, 1000);
      });
    });
  </script>
</Layout>