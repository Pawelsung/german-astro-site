---
import Layout from '../layouts/Layout.astro';
import UserAccount from './UserAccount.jsx';

interface Frontmatter {
  title: string;
  description: string;
  tags?: string[];
}

interface Props {
  frontmatter: Frontmatter;
  contentClass?: string;
}

const { frontmatter, contentClass = 'w-full flex-grow relative z-10 px-4 pb-10' } = Astro.props;
const hasTips = await Astro.slots.has('tips');
---

<Layout title={frontmatter.title}>
  <main class="min-h-screen bg-[#FDFBF7] text-slate-800 flex flex-col">
    <div class="w-full px-4 pt-8 pb-2">
      <div class="max-w-4xl mx-auto">
        <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <a
            href="/"
            class="text-amber-600 font-black inline-flex items-center gap-2 hover:bg-amber-50 px-4 py-2 rounded-xl transition-all w-fit"
          >
            ← 返回課程總覽
          </a>
          <UserAccount client:only="react" compact />
        </div>

        <h1 class="text-3xl md:text-5xl font-black text-slate-800 mb-4 tracking-tight leading-tight">
          {frontmatter.title}
        </h1>

        {frontmatter.tags?.length && (
          <div class="flex flex-wrap gap-2 mb-6">
            {frontmatter.tags.map((tag) => (
              <span class="px-3 py-1 bg-amber-50 text-amber-600 text-xs font-black rounded-full border border-amber-100 shadow-sm">
                #{tag}
              </span>
            ))}
          </div>
        )}

        <p class="text-slate-600 leading-relaxed font-medium text-sm md:text-base">
          {frontmatter.description}
        </p>
      </div>
    </div>

    <div class={contentClass}>
      <slot />
    </div>

    {hasTips && (
      <div class="w-full px-4 pb-12 mt-2 mb-8 relative z-0">
        <div class="max-w-4xl mx-auto bg-amber-50 p-6 rounded-[2rem] border border-amber-100 shadow-sm">
          <h3 class="text-lg font-black text-amber-800 mb-4 flex items-center gap-2">
            <span class="text-2xl">💡</span> 學習小撇步
          </h3>

          <ul class="space-y-4 text-sm text-amber-700 font-bold">
            <slot name="tips" />
          </ul>
        </div>
      </div>
    )}
  </main>
</Layout>
