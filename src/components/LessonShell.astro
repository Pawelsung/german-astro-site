---
import Layout from '../layouts/Layout.astro';
import UserAccount from './UserAccount.jsx';

interface Frontmatter {
  title: string;
  description: string;
  tags?: string[];
}

interface Props {
  frontmatter: Frontmatter;
  contentClass?: string;
}

const { frontmatter, contentClass = 'w-full flex-grow relative z-10 px-4 pb-10' } = Astro.props;
const hasTips = await Astro.slots.has('tips');
---

<Layout title={frontmatter.title}>
  <main class="min-h-screen bg-[#FDFBF7] text-slate-800 flex flex-col">
    <div class="w-full px-4 pt-5 md:pt-4 pb-3">
      <div class="max-w-6xl mx-auto">
        <div class="mb-4 md:mb-3 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <a
            href="/"
            class="text-amber-600 font-black inline-flex items-center gap-2 hover:bg-amber-50 px-3 py-2 rounded-xl transition-all w-fit text-sm"
          >
            ← 返回課程總覽
          </a>
          <UserAccount client:only="react" compact />
        </div>

        <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div class="min-w-0">
            <h1 class="text-2xl md:text-3xl font-black text-slate-800 tracking-tight leading-tight">
              {frontmatter.title}
            </h1>

            <p class="mt-2 max-w-3xl text-slate-600 leading-relaxed font-medium text-sm">
              {frontmatter.description}
            </p>
          </div>

          {frontmatter.tags?.length && (
            <div class="flex flex-wrap gap-2 md:max-w-sm md:justify-end">
              {frontmatter.tags.slice(0, 4).map((tag) => (
                <span class="px-2.5 py-1 bg-amber-50 text-amber-600 text-[11px] font-black rounded-full border border-amber-100 shadow-sm">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>

    <div class={contentClass}>
      <slot />
    </div>

    {hasTips && (
      <div class="w-full px-4 pb-12 mt-2 mb-8 relative z-0">
        <div class="max-w-4xl mx-auto bg-amber-50 p-6 rounded-[2rem] border border-amber-100 shadow-sm">
          <h3 class="text-lg font-black text-amber-800 mb-4 flex items-center gap-2">
            <span class="text-2xl">💡</span> 學習小撇步
          </h3>

          <ul class="space-y-4 text-sm text-amber-700 font-bold">
            <slot name="tips" />
          </ul>
        </div>
      </div>
    )}
  </main>
</Layout>
